  "num_hidden_layers": 24,
  "max_position_embeddings": 4096,
  "initializer_range": 0.01,
  "hidden_act": "silu",

  "layer_types": [
    "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_attention",
    "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_attention",
    "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_attention",
    "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_attention",
    "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_attention",
    "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_5_gdn", "qwen3_attention"
  ],
  "ffn_types": [
    "qwen3_mlp", "qwen3_mlp", "qwen3_mlp", "qwen3_mlp",
    "qwen3_mlp", "qwen3_mlp", "qwen3_mlp", "qwen3_mlp",
    "qwen3_mlp", "qwen3_mlp", "qwen3_mlp", "qwen3_mlp",
    "qwen3_mlp", "qwen3_mlp", "qwen3_mlp", "qwen3_mlp",
    "qwen3_mlp", "qwen3_mlp", "qwen3_mlp", "qwen3_mlp",
    "qwen3_mlp", "qwen3_mlp", "qwen3_mlp", "qwen3_mlp"
